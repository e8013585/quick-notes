{
  "manifest_version": 3,
  "name": "__MSG_appName__",
  "version": "1.0.0",
  "description": "__MSG_appDesc__",
  "default_locale": "en",
  "permissions": [
    "storage",
    "activeTab",
    "scripting",
    "tabs"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon_full.png",
      "32": "icons/icon_full.png",
      "48": "icons/icon_full.png",
      "128": "icons/icon_full.png"
    },
    "default_title": "__MSG_appTitle__"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon_full.png",
    "32": "icons/icon_full.png",
    "48": "icons/icon_full.png",
    "128": "icons/icon_full.png"
  }
}
